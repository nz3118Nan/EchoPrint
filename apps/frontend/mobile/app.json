{
  "expo": {
    "name": "EchoPoint",
    "slug": "echopoint",
    "scheme": "echoprint",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "bundleIdentifier": "com.nz3118.echoprint"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow EchoPoint to record voice echoes.",
          "enableBackgroundRecording": false
        }
      ]
    ]
  }
}
