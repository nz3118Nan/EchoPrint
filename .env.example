# Local PostgreSQL
POSTGRES_DB=echoprint
POSTGRES_USER=echoprint
POSTGRES_PASSWORD=echoprint
POSTGRES_PORT=5450

# Local Redis
REDIS_PORT=6400

# Backend and frontend
BACKEND_PORT=8011
FRONTEND_PORT=8010

# Supabase Auth (safe to expose to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
VITE_BACKEND_URL=http://localhost:8011/echoprint/api

# Backend-only OpenAI transcription settings
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
